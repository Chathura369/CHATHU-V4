# --- Core dashboard ---
# PORT — bind the dashboard HTTP server on this port. Free hosts (Railway,
# Render, Fly, etc.) inject PORT automatically; leave unset there.
PORT=5000
# HOST — interface to bind. Use 0.0.0.0 inside containers so the platform
# can route traffic to the process. Defaults to 0.0.0.0.
HOST=0.0.0.0

# --- Persistence ---
# DATA_DIR — single root for all stateful files (db.json, WhatsApp sessions,
# downloads, generated JWT secret). Set this to a mounted persistent volume
# on Railway / Render / Fly / Heroku-style hosts so state survives deploys.
# Example: DATA_DIR=/data
# When unset the app writes inside the repo directory (fine for local dev).
DATA_DIR=

# --- Bot identity ---
BOT_NAME=Chathu MD
OWNER_NUMBER=
PREFIX=.

# --- Admin auth ---
# ADMIN_PASS is required before dashboard login. JWT_SECRET is auto-generated
# and persisted under DATA_DIR/.jwt_secret on first boot if not provided here.
ADMIN_USER=admin
ADMIN_PASS=
JWT_SECRET=
PREMIUM_CODE=

# --- Runtime defaults ---
WORK_MODE=public
AUTO_READ=false
AUTO_TYPING=true
NSFW_ENABLED=false

# --- AI providers (optional, all unset = AI disabled) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Optional search providers ---
OMDB_API_KEY=
OPENWEATHER_API_KEY=
NEWS_API_KEY=
